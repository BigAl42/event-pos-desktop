{
  "name": "kassensystem",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "e2e-handbook-screenshots"
  ],
  "scripts": {
    "prepare": "husky || true",
    "predev": "node scripts/sync-handbook-assets.mjs",
    "prebuild": "node scripts/sync-handbook-assets.mjs",
    "dev": "vite",
    "dev:slave": "vite --port 1421",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:all": "npm run test:run && cd src-tauri && cargo test --features test",
    "test:rust:docker": "bash scripts/docker-rust-test.sh",
    "tauri": "tauri",
    "tauri:master": "cross-env KASSEN_INSTANCE=master npm run tauri dev",
    "tauri:slave": "cross-env KASSEN_INSTANCE=slave npm run tauri dev -- --config src-tauri/tauri.slave.json",
    "handbook:screenshots": "npm --prefix e2e-handbook-screenshots run capture",
    "handbook:placeholders": "node scripts/render-handbuch-placeholders.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "i18next": "^25.8.20",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "sharp": "^0.33.5",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.6"
  }
}
