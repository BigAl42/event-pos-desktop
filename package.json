{
  "name": "kassensystem",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "husky || true",
    "dev": "vite",
    "dev:slave": "vite --port 1421",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:all": "npm run test:run && cd src-tauri && cargo test --features test",
    "tauri": "tauri",
    "tauri:master": "cross-env KASSEN_INSTANCE=master npm run tauri dev",
    "tauri:slave": "cross-env KASSEN_INSTANCE=slave npm run tauri dev -- --config src-tauri/tauri.slave.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "cross-env": "^7.0.3",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "husky": "^9.1.7",
    "vitest": "^2.1.6"
  }
}
